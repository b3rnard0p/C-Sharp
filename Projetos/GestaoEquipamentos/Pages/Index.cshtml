@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="anim-fade-up">
    <div class="page-header position-relative mb-4">
        <h1 class="page-title m-0" style="font-weight: 700;">Visão <span>Geral</span></h1>
    </div>

    <div class="row g-4">
        <!-- Top 5 Equipamentos -->
        <div class="col-md-6">
            <div class="glass-card h-100" style="padding: 1.5rem;">
                <h4 class="mb-4" style="font-weight: 700; color: var(--text-primary); font-size: 1.25rem;">
                    <i data-lucide="bar-chart-2" style="color: var(--accent-primary); width: 1.2em; height: 1.2em; margin-right: 8px;"></i>
                    Equipamentos Mais Emprestados
                </h4>
                
                @if (Model.TopEquipamentos.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var ranking in Model.TopEquipamentos)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center" style="background: transparent; border-color: var(--border-muted); padding: 1rem 0;">
                                <div>
                                    <h6 class="mb-1" style="font-weight: 600;">@ranking.Equipamento.Nome</h6>
                                    <small class="text-muted">Patrimônio: @ranking.Equipamento.CodigoPatrimonio</small>
                                </div>
                                <span class="badge" style="background-color: var(--bg-card); border: 1px solid var(--border-muted); color: var(--text-primary); font-size: 0.9rem; padding: 0.5rem 0.8rem; border-radius: var(--radius-sm);">
                                    @ranking.QuantidadeEmprestimos empréstimo(s)
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mt-4">Nenhum empréstimo registrado ainda.</p>
                }
            </div>
        </div>

        <!-- Equipamentos em Manutenção -->
        <div class="col-md-6">
            <div class="glass-card h-100" style="padding: 1.5rem;">
                <h4 class="mb-4" style="font-weight: 700; color: var(--text-primary); font-size: 1.25rem;">
                    <i data-lucide="wrench" style="color: #ef4444; width: 1.2em; height: 1.2em; margin-right: 8px;"></i>
                    Em Manutenção
                </h4>
                
                @if (Model.EquipamentosEmManutencao.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var equip in Model.EquipamentosEmManutencao)
                        {
                            <div class="list-group-item d-flex align-items-center" style="background: transparent; border-color: var(--border-muted); padding: 1rem 0;">
                                <div style="width: 40px; height: 40px; border-radius: 8px; background-color: #fee2e2; color: #991b1b; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0;">
                                    <i data-lucide="alert-triangle" style="width: 1.2em; height: 1.2em;"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1" style="font-weight: 600;">@equip.Nome</h6>
                                    <small class="text-muted">ID: @equip.Id | Patrimônio: @equip.CodigoPatrimonio</small>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mt-4">Nenhum equipamento em manutenção no momento. Tudo operando bem!</p>
                }
            </div>
        </div>
    </div>
</div>
