@page
@using TrabalhoFinal.Models
@model TrabalhoFinal.Pages.Equipamentos.EditarModel
@{
    ViewData["Title"] = "Editar Equipamento";
}

<div class="anim-fade-up" style="max-width: 600px; margin: 0 auto;">
    <div class="page-header position-relative d-flex justify-content-center align-items-center mb-4">
        <a asp-page="/Equipamentos/Index" class="btn btn-secondary position-absolute start-0" title="Voltar"><i data-lucide="arrow-left" style="width:1em;height:1em;"></i></a>
        <h1 class="page-title text-center m-0"><span>Editar</span> Equipamento</h1>
    </div>

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert" style="border-radius: var(--radius-md); font-size: 0.9rem;">
            <i data-lucide="alert-circle" style="width: 1.2em; height: 1.2em; margin-right: 8px;"></i>
            @TempData["Erro"]
        </div>
    }

    <div class="form-card">
        @if (!Model.MostrarFormulario)
        {
            <div class="mb-4 text-center">
                <h4 class="mb-2">@Model.EquipamentoAlvo?.Nome</h4>
                <p class="text-muted mb-0">Para acessar a edição deste equipamento, informe o seu Código Interno de Patrimônio.</p>
            </div>

            <form method="post" asp-page-handler="Buscar">
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-4">
                    <label asp-for="CodigoInformado" class="form-label font-weight-bold">Código de Patrimônio</label>
                    <input asp-for="CodigoInformado" type="text" class="form-control" placeholder="Ex: PAT-123" autofocus />
                </div>

                <hr class="divider mb-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-page="/Equipamentos/Index" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary d-flex align-items-center gap-2">
                        <i data-lucide="unlock" style="width: 1em; height: 1em;"></i> Acessar Edição
                    </button>
                </div>
            </form>
        }
        else
        {
            <form method="post" asp-page-handler="Salvar">
                <input type="hidden" asp-for="Equipamento.Id" />
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CodigoInformado" />

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Código Identificador (ID)</label>
                    <input type="text" class="form-control" value="@Model.Equipamento.Id" disabled style="background-color: var(--bg-body);" />
                </div>

                <div class="mb-3">
                    <label asp-for="Equipamento.Nome" class="form-label font-weight-bold">Nome ou Descrição</label>
                    <input asp-for="Equipamento.Nome" class="form-control" placeholder="Ex: Notebook Dell Inspiron" autofocus />
                    <span asp-validation-for="Equipamento.Nome" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Equipamento.CodigoPatrimonio" class="form-label font-weight-bold">Código Interno de Patrimônio</label>
                    <input asp-for="Equipamento.CodigoPatrimonio" class="form-control" placeholder="Mínimo 6 caracteres" />
                    <span asp-validation-for="Equipamento.CodigoPatrimonio" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Equipamento.Situacao" class="form-label font-weight-bold">Situação Atual</label>
                    <select asp-for="Equipamento.Situacao" class="form-select">
                        <option value="">Selecione uma situação...</option>
                        <option value="@SituacaoEquipamento.Disponivel">Disponível</option>
                        <option value="@SituacaoEquipamento.EmUso">Em Uso</option>
                        <option value="@SituacaoEquipamento.Manutencao">Manutenção</option>
                    </select>
                    <span asp-validation-for="Equipamento.Situacao" class="text-danger small"></span>
                </div>

                <hr class="divider mb-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-page="/Equipamentos/Index" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary d-flex align-items-center gap-2">
                        <i data-lucide="save" style="width: 1em; height: 1em;"></i> Salvar Alterações
                    </button>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
