@page
@model WebApplication1.Pages.Usuarios.DetalhesModel
@{
    ViewData["Title"] = "Detalhes do Usuário";
}

<h2>@ViewData["Title"]</h2>

<div>
    <label>Id: </label>
    <span>@Model.usuario.Id</span>
</div>

<div>
    <label>Nome: </label>
    <span>@Model.usuario.Nome</span>
</div>

<div>
    <label>Senha: </label>
    <span>@Model.usuario.Senha</span>
</div>

<div>
    <label>Enail: </label>
    <span>@Model.usuario.Email</span>
</div>

<a class="btn btn-secondary" asp-page="/Usuarios/Index">Voltar</a>